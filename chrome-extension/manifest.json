{
  "manifest_version": 3,
  "name": "Sona Emotion Sprites",
  "version": "1.1.1",
  "description": "Unofficial fan extension that turns model-specific emotion tags into local persona sprites on Claude, ChatGPT, and Gemini.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.png"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://gemini.google.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "aisonas@kodee2k",
  "data_collection_permissions": { "required": ["none"], "optional": []},
      "strict_min_version": "140.0"
    }
  }
}
